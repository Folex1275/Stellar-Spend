{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/app/**/*.{ts,tsx}",
    "src/lib/index.ts"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/stories/**",
    "src/test/**",
    "src/**/*.test.{ts,tsx}",
    "src/**/*.stories.{ts,tsx}"
  ],
  "ignoreDependencies": [
    "@storybook/*"
  ]
}
